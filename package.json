{
  "name": "haru-root",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @haru/db db:generate",
    "db:migrate": "pnpm --filter @haru/db db:migrate",
    "db:push": "pnpm --filter @haru/db db:push",
    "db:seed": "pnpm --filter @haru/db db:seed"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@stylistic/eslint-plugin": "catalog:",
    "@types/eslint-plugin-promise": "catalog:",
    "@types/node": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-n": "catalog:",
    "eslint-plugin-promise": "catalog:",
    "eslint-plugin-regexp": "catalog:",
    "eslint-plugin-unicorn": "catalog:",
    "globals": "catalog:",
    "jiti": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:tseslint",
    "typescript-eslint": "catalog:"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24 || ^25",
      "onFail": "warn"
    }
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
