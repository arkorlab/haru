{
  "name": "@haru/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "haru control server: fleet API, reconciler, route intent, and OpenAI-compatible chat proxy",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware --deny-warnings . && eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@haru/core": "workspace:*",
    "@haru/db": "workspace:*",
    "@haru/driver-skypilot": "workspace:*",
    "@haru/driver-skyserve": "workspace:*",
    "@haru/protocol": "workspace:*",
    "@hono/node-server": "catalog:",
    "hono": "catalog:",
    "undici": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
